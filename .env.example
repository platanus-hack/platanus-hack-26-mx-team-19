# Copy to .env.local (Next.js loads .env.local in development)

NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Required if agentatlas-services expects HTTP Basic on unauthenticated routes (format: username:password)
# NEXT_PUBLIC_API_BASIC_AUTH=user:password
